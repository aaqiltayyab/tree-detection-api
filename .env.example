# ── Copy this file to .env and fill in your values ──────────────────────────

# ── CLIP Model ────────────────────────────────────────────────────────────────
# Auto-downloaded from HuggingFace on first run (~600 MB). Free, no API key.
CLIP_MODEL=openai/clip-vit-base-patch32

# Prompts that mean "yes, a tree is present". Add more for better recall.
TREE_POSITIVE_PROMPTS=a photo of a tree,a photo of trees,a photo of a forest,a photo of a palm tree,a photo of a plant or tree

# Prompts that calibrate the score — what "no tree" looks like.
TREE_NEGATIVE_PROMPTS=a photo with no trees,a photo of a building,a photo of a person,a photo of an indoor scene

# Score threshold (0–1). Lower = more sensitive, more false positives.
# 0.40 is a good starting point; raise to 0.50 if you get false positives.
CONFIDENCE_THRESHOLD=0.40

# ── HuggingFace cache ─────────────────────────────────────────────────────────
# Where the downloaded CLIP weights are stored locally.
# Default (~/.cache/huggingface) works fine for local dev.
# For cloud: set this to a persistent volume path so the model is not
# re-downloaded on every redeploy (e.g. /data/hf_cache on Render/Railway).
# HF_HOME=/data/hf_cache

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=10485760
ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp

# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
